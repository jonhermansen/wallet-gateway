{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "global": {
            "description": "Global values shared between all subcharts",
            "$comment": "Added automatically by 'helm schema' to allow this chart to be used as a Helm dependency, as the `additionalProperties` setting would otherwise collide with Helm's special 'global' values key.",
            "type": [
                "object",
                "null"
            ]
        },
        "image": {
            "type": "object",
            "properties": {
                "repo": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "kernel": {
            "type": "object",
            "properties": {
                "clientType": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "userUrl": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "store": {
            "type": "object",
            "properties": {
                "connection": {
                    "type": "object",
                    "properties": {
                        "database": {
                            "type": "string"
                        },
                        "type": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "idps": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "configUrl": {
                                "type": "string"
                            },
                            "id": {
                                "type": "string"
                            },
                            "issuer": {
                                "type": "string"
                            },
                            "type": {
                                "type": "string"
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "networks": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "adminAuth": {
                                "type": "object",
                                "properties": {
                                    "audience": {
                                        "type": "string"
                                    },
                                    "clientId": {
                                        "type": "string"
                                    },
                                    "clientSecret": {
                                        "type": "string"
                                    },
                                    "issuer": {
                                        "type": "string"
                                    },
                                    "method": {
                                        "type": "string"
                                    },
                                    "scope": {
                                        "type": "string"
                                    }
                                },
                                "additionalProperties": false
                            },
                            "auth": {
                                "type": "object",
                                "properties": {
                                    "audience": {
                                        "type": "string"
                                    },
                                    "clientId": {
                                        "type": "string"
                                    },
                                    "clientSecret": {
                                        "type": "string"
                                    },
                                    "issuer": {
                                        "type": "string"
                                    },
                                    "method": {
                                        "type": "string"
                                    },
                                    "scope": {
                                        "type": "string"
                                    }
                                },
                                "additionalProperties": false
                            },
                            "description": {
                                "type": "string"
                            },
                            "id": {
                                "type": "string"
                            },
                            "identityProviderId": {
                                "type": "string"
                            },
                            "ledgerApi": {
                                "type": "object",
                                "properties": {
                                    "baseUrl": {
                                        "type": "string"
                                    }
                                },
                                "additionalProperties": false
                            },
                            "name": {
                                "type": "string"
                            },
                            "synchronizerId": {
                                "type": "string"
                            }
                        },
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}
