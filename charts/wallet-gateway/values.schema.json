{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "global": {
            "description": "Global values shared between all subcharts",
            "$comment": "Added automatically by 'helm schema' to allow this chart to be used as a Helm dependency, as the `additionalProperties` setting would otherwise collide with Helm's special 'global' values key.",
            "type": [
                "object",
                "null"
            ]
        },
        "imageRepo": {
            "type": "string"
        },
        "imageTag": {
            "type": "string"
        },
        "kernel": {
            "type": "object",
            "properties": {
                "clientType": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "userUrl": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "store": {
            "type": "object",
            "properties": {
                "connection": {
                    "type": "object",
                    "properties": {
                        "database": {
                            "type": "string"
                        },
                        "type": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "networks": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": false
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}
